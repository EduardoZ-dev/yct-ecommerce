# Copia este archivo a `.env` y completa los valores. NO lo subas a git.

# Dominio base (el API quedará en api.TUDOMINIO)
DOMAIN=tudominio.com

# Contraseña del SA de SQL Server (fuerte: 12+ caracteres, may/min/número/símbolo)
MSSQL_SA_PASSWORD=Cambiar_Esto_123!

# JWT (clave larga y secreta, 32+ caracteres)
JWT_KEY=clave-secreta-muy-larga-cambiar-por-favor-0123456789
JWT_ISSUER=YCT.API
JWT_AUDIENCE=YCT.Clients

# Orígenes de los frontends (CORS) — con https://
ACOPIO_ORIGIN=https://acopio.tudominio.com
CHOFER_ORIGIN=https://chofer.tudominio.com
TIENDA_ORIGIN=https://tienda.tudominio.com

# SMTP para notificaciones (Gmail, Brevo, etc.). Ajusta claves según appsettings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASSWORD=clave-de-aplicacion
SMTP_FROM=tucorreo@gmail.com
